<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dungeon_bg"
    android:padding="16dp"
    tools:context=".TiendaActivity">

    <!-- Título de la Tienda -->
    <TextView
        android:id="@+id/tvTituloTienda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BAZAR DEL CAMPAMENTO"
        android:textColor="@color/dungeon_gold"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Contador de Monedas -->
    <LinearLayout
        android:id="@+id/layoutMonedas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloTienda"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰 "
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvMonedasTienda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/dungeon_gold_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="serif" />
    </LinearLayout>

    <!-- Contenedor dinámico de objetos -->
    <ScrollView
        android:id="@+id/scrollViewTienda"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="Lista de objetos disponibles en la tienda"
        app:layout_constraintTop_toBottomOf="@id/layoutMonedas"
        app:layout_constraintBottom_toTopOf="@id/tvAviso"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/containerObjetos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <TextView
        android:id="@+id/tvAviso"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Más objetos próximamente..."
        android:textColor="@color/dungeon_text_hint"
        android:textSize="12sp"
        android:fontFamily="serif"
        app:layout_constraintBottom_toTopOf="@id/btnVolverTienda"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnVolverTienda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VOLVER AL MENÚ"
        android:textColor="@color/dungeon_text_light"
        android:backgroundTint="@color/dungeon_gold_btn"
        android:fontFamily="serif"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>